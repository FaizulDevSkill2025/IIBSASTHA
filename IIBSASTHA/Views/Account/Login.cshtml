@using IIBSASTHA.ViewModels;
@model LoginViewModel;



@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="account-container">

    <div class="account-box">

        <h2 class="text-center mb-4">Sign In</h2>

        <hr />

        <form app-action="Login" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3">

                <label asp-for="Email" class="form-label" aria-required="true" placeholder="name@example.com"></label>

                <input asp-for="Email" class="form-control"/>

                <span asp-validation-for="Email" class="text-danger"> </span>

            </div>

            <div class="form-floating mb-3">

                <label asp-for="Password" class="form-label" aria-required="true" placeholder="Password"></label>

                <input asp-for="Password" class="form-control"/>

                <span asp-validation-for="Password" class="text-danger"> </span>

            </div>
            <div class="float-end">
                <a asp-controller="Account" asp-action="VerifyEmail" class="text-decoration-none">
                    Forgot Password ?
                </a>
            </div>
            <div class="form-check mb-3">

                <label class="form-check-label">

                    <input asp-for="RememberMe" class="form-check-input"/>

                     @Html.DisplayNameFor(a=> a.RememberMe)

                </label>

            </div>

                <div>

                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Submit</button>

                </div>

             @*   <input type="submit" value="Login" class="btn btn-success w-100 p-2"/> *@

           @*  <div class="text-center">

                <a asp-controller="Home" asp-action="Index" class="text-decoration-none mt-3">Back</a>

            </div> *@
            <p class="text-center mt-2">
                Don't have an account ? <a asp-controller="Account" asp-action="Register" class="text-decoration-none">Register</a>
            </p>

        </form>

    </div>

</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial.cshtml" />
}
